# Example .env for lithos-loom.
#
# Copy to .env (in CWD when running `lithos-loom run`) or set these
# variables in your shell rc. python-dotenv loads .env automatically.

# Required: where Lithos is reachable.
LITHOS_URL=http://localhost:8765

# Optional: explicit config path. Beats LITHOS_LOOM_ENVIRONMENT.
# LITHOS_LOOM_CONFIG=/home/you/.config/lithos-loom/config.toml

# Optional: pick a per-environment config (config.<env>.toml) from the
# search paths. Useful for switching between dev / prod / experiment
# Lithos targets on the same workstation.
# LITHOS_LOOM_ENVIRONMENT=dev
